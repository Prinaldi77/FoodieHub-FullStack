<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Food Image -->
        <ImageView
            android:id="@+id/iv_manage_image"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:src="@drawable/menu"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Food Info -->
        <TextView
            android:id="@+id/tv_manage_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Bakso Urat Spesial"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_manage_image"
            app:layout_constraintEnd_toStartOf="@id/btn_edit_menu"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_manage_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rp 25.000"
            android:textColor="@color/maroon"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_manage_name"
            app:layout_constraintStart_toStartOf="@id/tv_manage_name" />

        <TextView
            android:id="@+id/tv_manage_stock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Stok: 50"
            android:textColor="#888888"
            android:textSize="11sp"
            app:layout_constraintTop_toBottomOf="@id/tv_manage_price"
            app:layout_constraintStart_toStartOf="@id/tv_manage_name" />

        <!-- Edit Button -->
        <ImageView
            android:id="@+id/btn_edit_menu"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/maroon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_delete_menu" />

        <!-- Delete Button -->
        <ImageView
            android:id="@+id/btn_delete_menu"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#D32F2F"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
