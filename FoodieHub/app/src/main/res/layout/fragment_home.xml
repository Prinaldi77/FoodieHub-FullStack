<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ═══ BANNER PROMO (Image Slider) ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/out_card_view_home"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="17dp">

            <com.denzcoskun.imageslider.ImageSlider
                android:id="@+id/image_slider"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:iss_auto_cycle="true"
                app:iss_period="3000"
                app:iss_delay="1000"
                android:textAlignment="center" />
        </androidx.cardview.widget.CardView>

        <!-- ═══ HEADER SECTION: Terpopuler ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp">

            <TextView
                android:id="@+id/popular"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🍜 Terpopuler"
                android:textSize="16sp"
                android:textColor="@color/maroon"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/view_menu"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Lihat Semua Menu"
                android:background="@drawable/white_button"
                android:textColor="@color/maroon"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:paddingHorizontal="10dp" />
        </LinearLayout>

        <!-- ═══ RECYCLERVIEW: Makanan Terpopuler (dari DB sendiri) ═══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/PopularRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="16dp"
            android:nestedScrollingEnabled="false" />

        <!-- ═══ DIVIDER ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <!-- ═══ HEADER SECTION: Inspirasi Kuliner (API Publik TheMealDB) ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_inspiration_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌍 Inspirasi Kuliner Dunia"
                android:textSize="16sp"
                android:textColor="@color/maroon"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_powered_by"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="via TheMealDB"
                android:textSize="10sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Sub-label keterangan API publik -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingBottom="10dp"
            android:text="Temukan inspirasi masakan dari seluruh dunia, diambil secara real-time"
            android:textSize="11sp"
            android:textColor="#888888" />

        <!-- Loading indicator saat fetch API -->
        <ProgressBar
            android:id="@+id/pb_inspiration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- ═══ RECYCLERVIEW HORIZONTAL: Inspirasi dari TheMealDB ═══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_meal_inspiration"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
