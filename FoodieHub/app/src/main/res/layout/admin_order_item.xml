<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Order ID & User info -->
        <TextView
            android:id="@+id/tv_admin_order_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Order #b1a2c3d4..."
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_admin_order_status" />

        <TextView
            android:id="@+id/tv_admin_order_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pelanggan: Aldi Prinaldi (aldi@gmail.com)"
            android:textColor="#555555"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_order_id"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_admin_order_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Alamat: Gg. Melati, Purwokerto"
            android:textColor="#777777"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_order_user"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/order_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E5EA"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_admin_order_address" />

        <!-- Total Price -->
        <TextView
            android:id="@+id/tv_admin_order_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Total: Rp 75.000"
            android:textColor="@color/maroon"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/order_divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Order Status Badge -->
        <TextView
            android:id="@+id/tv_admin_order_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textColor="@color/maroon"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/white_button"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Update Status Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_update_status"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Ubah Status"
            android:textColor="@color/white"
            android:background="@drawable/maroon_button"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/order_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="6dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
