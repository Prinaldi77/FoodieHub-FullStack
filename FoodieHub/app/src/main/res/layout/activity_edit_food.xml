<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".EditFoodActivity">

    <!-- Header Toolbar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/toolbar_edit"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btn_back_edit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/maroon" />

            <TextView
                android:id="@+id/tv_title_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btn_back_edit"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Form Menu Makanan"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- ScrollView Form -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_edit"
        app:layout_constraintBottom_toTopOf="@id/btn_save_food"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Nama Makanan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Menu"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_food_name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:hint="Masukkan nama menu"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Harga -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Harga (Rupiah)"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_food_price"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:hint="Masukkan harga (cth: 25000)"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Stok -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Stok Menu"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_food_stock"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:hint="Masukkan jumlah stok"
                android:inputType="number"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Kategori (Spinner/Autocomplete) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Kategori Menu"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_food_category"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:hint="Masukkan Kategori (Makanan/Minuman)"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Link Image URL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Link/URL Foto Makanan"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_food_image"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:hint="http://example.com/image.jpg"
                android:inputType="textUri"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <!-- Deskripsi Menu -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Deskripsi Lengkap"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_food_desc"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/white_button"
                android:hint="Tuliskan deskripsi lengkap kuliner di sini..."
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:padding="16dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_save_food"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="24dp"
        android:background="@drawable/maroon_button"
        android:text="Simpan Menu Makanan"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
