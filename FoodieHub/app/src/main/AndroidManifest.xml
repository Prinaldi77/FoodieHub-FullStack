<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Izin Internet (wajib untuk API) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Izin Lokasi GPS (untuk fitur otomatis isi alamat via Nominatim API) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FoodieHub"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Halaman Pembayaran (WebView Midtrans) -->
        <activity
            android:name=".PaymentWebViewActivity"
            android:exported="false" />

        <!-- Halaman Panel Admin (Dashboard Admin) -->
        <activity
            android:name=".AdminActivity"
            android:exported="false" />

        <!-- Admin: Halaman Daftar Kelola Menu Makanan -->
        <activity
            android:name=".ManageMenuActivity"
            android:exported="false" />

        <!-- Admin: Form Tambah/Ubah Menu Makanan -->
        <activity
            android:name=".EditFoodActivity"
            android:exported="false" />

        <!-- Admin: Halaman Antrean Kelola Pesanan Customer -->
        <activity
            android:name=".AdminOrderActivity"
            android:exported="false" />

        <!-- Dialog Status Pesanan -->
        <activity
            android:name=".WindowDialogs"
            android:exported="false" />

        <!-- Pilih Lokasi Pengiriman -->
        <activity
            android:name=".ChooseYourLocation"
            android:exported="false" />

        <!-- Daftar Akun Baru -->
        <activity
            android:name=".SignUpActivity"
            android:exported="false" />

        <!-- Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Halaman Awal (Onboarding) -->
        <activity
            android:name=".StartActivity"
            android:exported="false" />

        <!-- Splash Screen - LAUNCHER (titik masuk aplikasi) -->
        <activity
            android:name=".SplashScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Halaman Utama Customer (Beranda, Keranjang, Riwayat, Cari, Profil) -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />

    </application>

</manifest>